{
  "identifier": "default",
  "description": "Default capabilities for novel reader",
  "local": true,
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:default",
    "core:webview:allow-create-webview-window",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open"
  ]
}
